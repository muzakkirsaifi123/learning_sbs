# Copy this to .env and fill in your values
# Never commit .env to git!

# From https://www.notion.so/my-integrations → Internal Integration Secret
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option A: sync an entire Notion Database
# Get from URL: notion.so/workspace/<DATABASE_ID>?v=...  (32-char hex, no dashes)
NOTION_DATABASE_ID=

# Option B: sync a single Notion Page
# Get from URL: notion.so/<title>-<PAGE_ID>  (last 32 chars)
NOTION_PAGE_ID=
